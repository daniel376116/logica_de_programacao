programa {
  funcao inicio() {
    cadeia nome 
     inteiro quantidade

    escreva("Digite seu nome: ")
    leia(nome)

    escreva("Digite a quantidade de vezes que deseja")
    escreva("a repetição de seu nome seu nome: ")
    leia(quantidade)

    para(inteiro i = 1; i <= quantidade; i++){
      escreva(nome, "\n")
    }


    
  }
}
