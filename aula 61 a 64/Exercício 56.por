programa {
  funcao inicio() {
    real numeros = 0, soma = 0

      escreva("Digite o número: ")
      leia(numeros)

    enquanto(numeros >= 0){
      soma = soma + numeros

      escreva("Digite o número: ")
      leia(numeros)
      

      
       }
       escreva("Soma: ",soma)
      
       
      
    
   }

    
  }
}
