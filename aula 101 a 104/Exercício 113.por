programa {
  funcao inicio() {
    inteiro posicao0, posicao1, posicao2
    inteiro numeros[5] = {posicao0, posicao1, posicao2, 54, 63}

    escreva("Digite o primeiro número: ")
    leia(posicao0)

    escreva("Digite o segundo número: ")
    leia(posicao1)

    escreva("Digite o terceiro número: ")
    leia(posicao2)

    escreva(numeros)
    
  }
}
