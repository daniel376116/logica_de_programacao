programa {
  funcao inicio() {
    inteiro numeros[4] = {40, 60, 80 , 100}

    inteiro soma = numeros[0] + numeros[3]
    escreva(soma,", ")

    inteiro multiplicacao = numeros[1] * numeros[2]
    escreva(multiplicacao,", ")

    inteiro subtracao = numeros[2] - numeros[0]
    escreva(subtracao)
    
  }
}
