programa {
  funcao inicio() {
    inteiro numero1, numero2
    
    escreva("Informe o 1° número: ")
    leia(numero1)

    escreva("Informe o 2° número: ")
    leia(numero2)

    se(numero1>numero2) {escreva("Número 1 maior que número 2", "\n")}
    senao {escreva("NÚmero 2 maior que número 1", numero1)} 
  
    
  }
}
