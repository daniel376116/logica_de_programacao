programa {
  funcao inicio() {
   inteiro a, b, c

   escreva("Informe o valor da constante A: ")
   leia(a)

   escreva("Informe o valor da constante B: ")
   leia(b)

   se(a== b) {c= a+b 
   escreva ("Valor da constante C: ", c)} 

   se(a!= b) {c= a* b escreva("Valor da constante C: ", c)}
    
  }
}
