programa
{
    funcao inicio()
    {
        real largura, altura, area
        
        escreva("Informe a largura: ")
        leia(largura)
        escreva("Informe a altura: ")
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}
// As variáveis largura e altura serem declaradas como inteiro. a ausência do escreva. 