programa
{
    funcao inicio()
    {
        cadeia senha

        escreva("Digite sua senha: ")
        leia(senha)

        se (senha == 1234)
        {
            escreva("Acesso liberado")
        }
        senao
        {
            escreva("Senha incorreta")
        }
    }
}
// A falta do escreva; operador lógico !=, o correto seria ==