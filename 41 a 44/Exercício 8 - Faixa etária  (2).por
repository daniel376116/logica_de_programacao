programa
{
    funcao inicio()
    {
        inteiro idade
        
        escreva("Informe sua idade: ")
        leia(idade)

        se ((idade >= 12) e (idade <= 17))
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        }
    }
}
// operador lógico OU, E seria o operador lógico correto.