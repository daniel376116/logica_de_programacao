programa {
  funcao inicio() {
    inteiro idade
    escreva("Informe a idade: ")
    leia(idade)

    escreva("Idade informada: ", idade)
  }
}
// Há dois erros. O primeiro é que não tem o "escreva", para indicar que o usuário
// precisa informar a idade. E o segundo erro é o número zero depois de "Idade informada:"
// impedindo que seja exibida a real idade informada pelo o usuário.
